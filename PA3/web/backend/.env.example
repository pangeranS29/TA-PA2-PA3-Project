# ──────────────────────────────────────────────────
#  SEJIWA Backend – Environment Variables
#  Copy file ini menjadi .env dan sesuaikan nilainya
# ──────────────────────────────────────────────────

# Application
APP_HOST=localhost
APP_PORT=8080
APP_ENDPOINT_V=v1
APP_ENVIRONMENT=development

# JWT
JWT_SECRET=ganti-dengan-rahasia-panjang-dan-acak-minimal-32-karakter

# ─────────────────────────────────────────────────────────────────────────
# DATABASE_URL  ←  Gunakan ini untuk Supabase (SSL otomatis)
# Format: postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require
# ─────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# PostgreSQL individual (tidak dipakai jika DATABASE_URL diisi)
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=sejiwa_db
DB_POSTGRES_USER=sejiwa_user
DB_POSTGRES_PASSWORD=sejiwa_pass
DB_POSTGRES_MAX_IDLE_CONNS=10
DB_POSTGRES_MAX_OPEN_CONNS=100
DB_POSTGRES_MAX_LIFE_TIME=10m
DB_POSTGRES_FLAVOR=
DB_POSTGRES_LOCATION=
DB_POSTGRES_TIMEOUT=30s
