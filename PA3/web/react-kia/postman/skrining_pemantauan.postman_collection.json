{
  "info": {
    "_postman_id": "pemantauan-anak-kia",
    "name": "KIA - Lembar Pemantauan Mingguan",
    "description": "Koleksi API untuk fitur Lembar Pemantauan Mingguan Anak (0-6 Tahun)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "    console.log(\"Token otomatis diupdate!\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Master Data",
      "item": [
        {
          "name": "Get Daftar Rentang Usia",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tenaga-kesehatan/pemantauan-anak/rentang-usia",
              "host": ["{{base_url}}"],
              "path": ["tenaga-kesehatan", "pemantauan-anak", "rentang-usia"]
            }
          }
        },
        {
          "name": "Get Indikator Gejala per Kategori",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tenaga-kesehatan/pemantauan-anak/kategori/1",
              "host": ["{{base_url}}"],
              "path": ["tenaga-kesehatan", "pemantauan-anak", "kategori", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Transaksi (Ibu / Kader)",
      "item": [
        {
          "name": "Simpan Lembar Pemantauan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"anak_id\": 1,\n    \"rentang_usia_id\": 1,\n    \"periode_waktu\": 1,\n    \"tanggal_periksa\": \"2026-05-01\",\n    \"pemeriksa\": \"Ibu Mandiri\",\n    \"detail_gejala\": [\n        {\n            \"kategori_tanda_sakit_id\": 1,\n            \"is_terjadi\": true\n        },\n        {\n            \"kategori_tanda_sakit_id\": 2,\n            \"is_terjadi\": false\n        }\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/tenaga-kesehatan/pemantauan-anak",
              "host": ["{{base_url}}"],
              "path": ["tenaga-kesehatan", "pemantauan-anak"]
            }
          }
        }
      ]
    },
    {
      "name": "Monitoring (Bidan)",
      "item": [
        {
          "name": "Lihat Riwayat Pemantauan Bayi",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tenaga-kesehatan/pemantauan-anak/history?anak_id=1&rentang_usia_id=1",
              "host": ["{{base_url}}"],
              "path": ["tenaga-kesehatan", "pemantauan-anak", "history"],
              "query": [
                { "key": "anak_id", "value": "1" },
                { "key": "rentang_usia_id", "value": "1" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Kelola Indikator (Admin)",
      "item": [
        {
          "name": "Tambah Indikator Gejala Baru",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"rentang_usia_id\": 1,\n    \"gejala\": \"Contoh Gejala Baru dari Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tenaga-kesehatan/pemantauan-anak/indikator",
              "host": ["{{base_url}}"],
              "path": ["tenaga-kesehatan", "pemantauan-anak", "indikator"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}